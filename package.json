{
  "name": "epm-complete",
  "version": "1.0.0",
  "dependencies": {
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "cds-plugin-ui5": "^0.17.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-purchase": "cds watch --open purchase/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "database": "db/epm.db"
        }
      },
      "auth": {
        "kind": "xsuaa",
        "[development]": {
          "kind": "mocked",
          "users": {
            "viewer@test.com": {
              "password": "pass",
              "roles": ["Read"]
            },
            "manager@test.com": {
              "password": "pass",
              "roles": ["Read", "Create", "Approve"]
            },
            "admin@test.com": {
              "password": "pass",
              "roles": ["Read", "Create", "Approve", "Delete", "Admin"]
            }
          }
        }
      }
    }
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/purchase"
  ]
}
