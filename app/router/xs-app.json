{
  "welcomeFile": "/purchase/index.html",
  "authenticationMethod": "none",
  "routes": [
    {
      "source": "^/purchasing/(.*)$",
      "target": "/purchasing/$1",
      "destination": "srv-api",
      "authenticationType": "none",
      "csrfProtection": false
    },
    {
      "source": "^/(.*)$",
      "target": "$1",
      "localDir": "resources",
      "authenticationType": "none"
    }
  ]
}
